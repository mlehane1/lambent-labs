# Google Tag Manager — get your container ID at https://tagmanager.google.com
# Then replace GTM-XXXXXXX in index.html with your real ID
# GTM handles GA4, Meta Pixel, TikTok Pixel — all configured inside GTM, not in code

# Anthropic API (server-side, for Build Preview feature)
# ANTHROPIC_API_KEY=your-key

# Supabase (server-side visitor tracking)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# IPinfo.io (IP enrichment — free tier: 50k lookups/mo)
# IPINFO_TOKEN=your-ipinfo-token
